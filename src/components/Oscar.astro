---
// Oscar the Lobster — 8-bit mascot. Edit the <rect>s to iterate.
// Props: size (px), claw (animate the left claw with a snap).
interface Props { size?: number; claw?: boolean; }
const { size = 118, claw = false } = Astro.props;
const clawCls = claw ? "claw-l" : "";
---
<svg class="oscar" viewBox="0 0 160 160" width={size} height={size}
     role="img" aria-label="Oscar the Lobster" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
  <g class="bob" fill="var(--l)">
    <rect x="60" y="26" width="6" height="10" fill="var(--d)"/><rect x="54" y="16" width="6" height="10" fill="var(--d)"/><rect x="49" y="8" width="6" height="8" fill="var(--d)"/>
    <rect x="94" y="26" width="6" height="10" fill="var(--d)"/><rect x="100" y="16" width="6" height="10" fill="var(--d)"/><rect x="106" y="8" width="6" height="8" fill="var(--d)"/>
    <g class={clawCls}>
      <rect x="14" y="42" width="26" height="9"/><rect x="14" y="58" width="18" height="9"/>
      <rect x="14" y="42" width="7" height="9" fill="var(--h)"/><rect x="38" y="54" width="18" height="8" fill="var(--d)"/>
    </g>
    <rect x="120" y="42" width="26" height="9"/><rect x="128" y="58" width="18" height="9"/>
    <rect x="139" y="42" width="7" height="9" fill="var(--h)"/><rect x="104" y="54" width="18" height="8" fill="var(--d)"/>
    <rect x="56" y="40" width="48" height="26"/><rect x="56" y="40" width="14" height="7" fill="var(--h)"/><rect x="98" y="40" width="6" height="26" fill="var(--d)"/>
    <rect x="63" y="47" width="13" height="13" fill="#fff"/><rect x="84" y="47" width="13" height="13" fill="#fff"/>
    <rect x="67" y="51" width="6" height="7" fill="#14181f"/><rect x="88" y="51" width="6" height="7" fill="#14181f"/>
    <rect class="lid" x="63" y="47" width="13" height="13" fill="var(--l)"/>
    <rect class="lid b" x="84" y="47" width="13" height="13" fill="var(--l)"/>
    <rect x="58" y="66" width="44" height="15"/><rect x="58" y="66" width="44" height="3" fill="var(--d)"/><rect x="96" y="66" width="6" height="15" fill="var(--d)"/>
    <rect x="61" y="81" width="38" height="15"/><rect x="61" y="81" width="38" height="3" fill="var(--d)"/><rect x="93" y="81" width="6" height="15" fill="var(--d)"/>
    <rect x="64" y="96" width="32" height="14"/><rect x="64" y="96" width="32" height="3" fill="var(--d)"/><rect x="90" y="96" width="6" height="14" fill="var(--d)"/>
    <rect x="50" y="74" width="8" height="7" fill="var(--d)"/><rect x="102" y="74" width="8" height="7" fill="var(--d)"/>
    <rect x="52" y="88" width="8" height="7" fill="var(--d)"/><rect x="100" y="88" width="8" height="7" fill="var(--d)"/>
    <rect x="64" y="110" width="32" height="10"/><rect x="64" y="110" width="32" height="3" fill="var(--d)"/>
    <rect x="54" y="120" width="20" height="13"/><rect x="72" y="120" width="16" height="13"/><rect x="86" y="120" width="20" height="13"/>
    <rect x="54" y="127" width="8" height="6" fill="var(--d)"/><rect x="98" y="127" width="8" height="6" fill="var(--d)"/><rect x="76" y="128" width="8" height="5" fill="var(--d)"/>
  </g>
</svg>
