---
// Oscar pulling out a laptop — shown in the link loader overlay.
// #loadbar is animated by the page script.
---
<svg class="oscar" viewBox="0 0 200 150" width="150" height="112"
     role="img" aria-label="Oscar with a laptop" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
  <g class="bob">
    <rect x="86" y="8" width="6" height="9" fill="var(--d)"/><rect x="80" y="0" width="6" height="9" fill="var(--d)"/>
    <rect x="108" y="8" width="6" height="9" fill="var(--d)"/><rect x="114" y="0" width="6" height="9" fill="var(--d)"/>
    <rect x="80" y="20" width="40" height="22" fill="var(--l)"/><rect x="80" y="20" width="12" height="6" fill="var(--h)"/>
    <rect x="86" y="26" width="10" height="10" fill="#fff"/><rect x="104" y="26" width="10" height="10" fill="#fff"/>
    <rect x="89" y="29" width="5" height="6" fill="#14181f"/><rect x="107" y="29" width="5" height="6" fill="#14181f"/>
    <rect class="lid" x="86" y="26" width="10" height="10" fill="var(--l)"/><rect class="lid b" x="104" y="26" width="10" height="10" fill="var(--l)"/>
    <rect x="84" y="42" width="32" height="12" fill="var(--l)"/>
    <rect x="34" y="52" width="20" height="9" fill="var(--l)"/><rect x="146" y="52" width="20" height="9" fill="var(--l)"/>
  </g>
  <rect x="50" y="60" width="100" height="60" rx="4" fill="#0e131c" stroke="#2b3850" stroke-width="2"/>
  <rect x="58" y="70" width="84" height="30" rx="2" fill="#0a0e15"/>
  <rect x="58" y="70" width="84" height="30" rx="2" fill="none" stroke="#1e2634" stroke-width="1"/>
  <rect id="loadbar" x="62" y="102" width="0" height="6" rx="3" fill="#e5484d"/>
  <rect x="40" y="118" width="120" height="8" rx="3" fill="#161c28" stroke="#2b3850" stroke-width="1.5"/>
</svg>
