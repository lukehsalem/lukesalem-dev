---
import { site } from "../data/site";
import { TECH } from "../data/tech";
import "../styles/portfolio.css";

const data = {
  site: {
    domain: site.domain, email: site.email, links: site.links, shipped: site.shipped, bio: site.bio,
    experience: site.experience, credentials: site.credentials, skills: site.skills,
    projects: site.projects, kpis: site.kpis, langs: site.langs, github: site.github,
  },
  tech: TECH,
};
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{site.name} — {site.domain}</title>
  <meta name="description" content={`${site.name} — CS @ FSU, Data Analyst II. Software, data, and fintech.`} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>
<div class="wrap">
  <div class="hero">
    <section class="window">
      <div class="titlebar"><span class="d3 rr"></span><span class="d3 yy"></span><span class="d3 gg"></span><span class="ttl">luke@lukesalem.dev — zsh</span></div>
      <div id="screen" role="log" aria-live="polite">
        <div id="history"></div>
        <div id="inputline" hidden><span class="prompt">luke</span><span class="muted">@</span><span class="path">dev</span><span class="muted">:~$</span>
          <input id="cmd" autocomplete="off" autocapitalize="off" spellcheck="false" aria-label="terminal input" /></div>
      </div>
    </section>
    <section class="intro">
      <div class="namerow">
        <div class="oscar-hero" id="heroActor"></div>
        <h1>luke<br/>salem<span class="dot">_</span></h1>
      </div>
      <div class="tag"><span class="rd">CS @ FSU '27</span> · <b>Data Analyst II</b> · <span class="amber">software + data + fintech</span></div>
      <p class="about-blurb" id="bio"></p>
      <div class="links" id="links"></div>
    </section>
  </div>

  <section class="sec">
    <div class="sec-head"><h2>credentials</h2></div>
    <div class="creds" id="creds"></div>
  </section>

  <section class="sec">
    <div class="sec-head"><h2>experience</h2></div>
    <div class="tl" id="exp"></div>
  </section>

  <section class="sec">
    <div class="sec-head"><h2>projects</h2></div>
    <div class="grid" id="projects"></div>
  </section>

  <section class="sec">
    <div class="sec-head"><h2>skills</h2></div>
    <div class="chips" id="skills"></div>
  </section>

  <section class="sec">
    <div class="sec-head"><h2>stats</h2><span class="cmt">// real, from GitHub</span></div>
    <div class="kpis" id="kpis"></div>
    <div class="statbox">
      <div class="t">contribution graph <span class="cm">// pulled live from GitHub API</span></div>
      <div class="ghcrop"><img src={`https://ghchart.rshah.org/e5484d/${site.github}`} alt={`${site.name} GitHub contributions`}
        onerror="this.parentElement.style.display='none';this.parentElement.nextElementSibling.style.display='block'" /></div>
      <div class="ghfail" style="display:none">contribution graph loads live from GitHub on the deployed site.</div>
    </div>
    <div class="statbox">
      <div class="t">languages <span class="cm">// across public repos</span></div>
      <div id="langs"></div>
    </div>
  </section>

  <footer>
    <span>© {year} luke salem</span>
    <span>monitored by <b>Oscar</b> 🦞</span>
    <span class="s" id="footLinks"></span>
  </footer>
</div>

<script type="application/json" id="data" set:html={JSON.stringify(data)}></script>

<script>
const D = JSON.parse(document.getElementById("data").textContent);
const SITE = D.site, TECH = D.tech;
const $ = (id) => document.getElementById(id);
const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;" }[c]));
const OPEN = (u) => window.open(u, "_blank", "noopener");
const badge = (n) => { const t = TECH[n] || { bg:"#232b3a", fg:"#cfd8e6" }; const ic = t.icon ? `<img src="https://cdn.simpleicons.org/${t.icon}/${t.ic}" alt="" loading="lazy" onerror="this.remove()"/>` : ""; return `<span class="badge" style="background:${t.bg};color:${t.fg}">${ic}${esc(n)}</span>`; };
const linkRow = (o) => Object.entries(o).map(([k,v]) => `<a href="${esc(v)}" target="_blank" rel="noopener">${k}</a>`).join("");

function flatOscar(size){ return `
<svg class="oscar osvg" viewBox="0 0 160 160" width="${size}" height="${size}" role="img" aria-label="Oscar the Lobster" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
 <g class="bob" fill="var(--l)">
  <rect x="60" y="26" width="6" height="10"/><rect x="54" y="16" width="6" height="10"/><rect x="49" y="8" width="6" height="8"/>
  <rect x="94" y="26" width="6" height="10"/><rect x="100" y="16" width="6" height="10"/><rect x="106" y="8" width="6" height="8"/>
  <g class="claw"><rect x="14" y="42" width="26" height="9"/><rect x="14" y="58" width="18" height="9"/><rect x="38" y="54" width="18" height="8"/></g>
  <rect x="120" y="42" width="26" height="9"/><rect x="128" y="58" width="18" height="9"/><rect x="104" y="54" width="18" height="8"/>
  <rect x="56" y="40" width="48" height="26"/>
  <rect x="63" y="47" width="13" height="13" fill="#fff"/><rect x="84" y="47" width="13" height="13" fill="#fff"/>
  <rect x="67" y="51" width="6" height="7" fill="#14181f"/><rect x="88" y="51" width="6" height="7" fill="#14181f"/>
  <rect class="lid" x="63" y="47" width="13" height="13" fill="var(--l)"/><rect class="lid b" x="84" y="47" width="13" height="13" fill="var(--l)"/>
  <rect x="58" y="67" width="44" height="14"/><rect x="61" y="82" width="38" height="14"/><rect x="64" y="97" width="32" height="13"/>
  <rect x="50" y="74" width="8" height="7"/><rect x="102" y="74" width="8" height="7"/><rect x="52" y="88" width="8" height="7"/><rect x="100" y="88" width="8" height="7"/>
  <rect x="64" y="111" width="32" height="10"/><rect x="54" y="121" width="20" height="12"/><rect x="72" y="121" width="16" height="12"/><rect x="86" y="121" width="20" height="12"/>
 </g></svg>`; }

function credIcon(k){ const S='<svg viewBox="0 0 24 24" width="34" height="34" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">';
 const I = {
  vanderbilt:`${S}<rect x="1" y="1" width="22" height="22" rx="3" fill="#1c1d22"/><rect x="5" y="5" width="3" height="4" fill="#caa14a"/><rect x="7" y="9" width="3" height="4" fill="#caa14a"/><rect x="9" y="13" width="3" height="3" fill="#caa14a"/><rect x="11" y="15" width="2" height="3" fill="#caa14a"/><rect x="16" y="5" width="3" height="4" fill="#caa14a"/><rect x="14" y="9" width="3" height="4" fill="#caa14a"/><rect x="12" y="13" width="3" height="3" fill="#caa14a"/></svg>`,
  ibm:`${S}<rect x="2" y="5" width="20" height="2" fill="#1F70C1"/><rect x="2" y="8" width="20" height="2" fill="#1F70C1"/><rect x="2" y="11" width="20" height="2" fill="#1F70C1"/><rect x="2" y="14" width="20" height="2" fill="#1F70C1"/><rect x="2" y="17" width="20" height="2" fill="#1F70C1"/></svg>`,
  harvard:`${S}<rect x="5" y="3" width="14" height="9" fill="#A51C30"/><rect x="6" y="12" width="12" height="2" fill="#A51C30"/><rect x="8" y="14" width="8" height="2" fill="#A51C30"/><rect x="10" y="16" width="4" height="2" fill="#A51C30"/><rect x="7" y="5" width="3" height="2" fill="#fff"/><rect x="14" y="5" width="3" height="2" fill="#fff"/><rect x="10" y="8" width="4" height="2" fill="#fff"/></svg>`,
  stanford:`${S}<rect x="11" y="15" width="2" height="6" fill="#6b4a2b"/><rect x="9" y="4" width="6" height="3" fill="#2E7D32"/><rect x="7" y="7" width="10" height="3" fill="#2E7D32"/><rect x="6" y="10" width="12" height="3" fill="#2E7D32"/><rect x="8" y="13" width="8" height="2" fill="#2E7D32"/></svg>`
 };
 return I[k] || `${S}<rect x="3" y="3" width="18" height="18" rx="3" fill="#233048"/></svg>`;
}

$("heroActor").innerHTML = flatOscar(78);
$("bio").textContent = SITE.bio;
const shipPill = `<span class="shipstat"><span class="pulse"></span><b>${SITE.shipped.count}</b> projects shipped in ${SITE.shipped.year}</span>`;
$("links").innerHTML = shipPill + linkRow(SITE.links);
$("footLinks").innerHTML = linkRow(SITE.links);
$("creds").innerHTML = SITE.credentials.map((c) => { const cl = c.link ? " clickable" : ""; const dop = c.link ? ` data-open="${esc(c.link)}"` : ""; const view = c.link ? `<div class="cview">${esc(c.linkText||"view certificate")} ↗</div>` : "";
  return `<div class="cred${cl}"${dop}><div class="ic">${credIcon(c.key)}</div><div><div class="o">${esc(c.org)}<span class="tg ${/progress/i.test(c.tag)?'prog':''}">${esc(c.tag)}</span></div><div class="ll">${esc(c.label)}</div><div class="nn">${esc(c.note)}</div>${view}</div></div>`; }).join("");
$("exp").innerHTML = SITE.experience.map((e) => `<div class="row"><div class="r1"><span class="role">${esc(e.role)}</span><span class="date">${esc(e.date)}</span></div><div class="org">${esc(e.org)}</div><div class="note">${esc(e.note)}</div></div>`).join("");
$("skills").innerHTML = SITE.skills.map((s) => `<span class="chip">${esc(s)}</span>`).join("");
$("kpis").innerHTML = SITE.kpis.map((k) => `<div class="kpi"><div class="n">${k.n}</div><div class="l">${esc(k.l)}</div></div>`).join("");
$("langs").innerHTML = SITE.langs.map((l) => `<div class="bar"><span>${esc(l.lbl)}</span><span class="track"><span class="fill" style="width:${l.pct}%"></span></span><span class="pct">${l.pct}%</span></div>`).join("");
$("projects").innerHTML = SITE.projects.map((p) => {
  const L=[]; if(p.github)L.push(`<a href="${esc(p.github)}" target="_blank" rel="noopener">code ↗</a>`);
  if(p.live)L.push(`<a href="${esc(p.live)}" target="_blank" rel="noopener">demo ↗</a>`);
  if(!p.github&&!p.live)L.push(`<span class="priv">private · in dev</span>`);
  return `<article class="card"><div class="peek">${flatOscar(60)}</div><div class="ct"><h3>${esc(p.name)}</h3>${p.status?`<span class="status">${esc(p.status)}</span>`:""}</div><p class="d">${esc(p.desc)}</p><div class="badges">${p.tech.map(badge).join("")}</div><div class="plinks">${L.join("")}</div></article>`;
}).join("");

// ===== INTERACTIVE TERMINAL (welcome menu · opens links) =====
const history = $("history"), inputline = $("inputline"), cmd = $("cmd"), screen = $("screen");
function tp(html){ const el = document.createElement("div"); el.className="out"; el.innerHTML=html; history.appendChild(el); screen.scrollTop=screen.scrollHeight; }
function pp(t){ tp(`<span class="prompt">luke</span><span class="muted">@</span><span class="path">dev</span><span class="muted">:~$</span> <span class="amber">${esc(t)}</span>`); }
const projList = () => SITE.projects.map((p,i) => { const link = p.github ? `<span class="tlink" data-open="${esc(p.github)}">open repo ↗</span>` : `<span class="muted">private · in dev</span>`; const demo = p.live ? ` · <span class="tlink" data-open="${esc(p.live)}">demo ↗</span>` : ""; return `  <span class="amber">[${i+1}]</span> <b>${esc(p.name)}</b>${p.status?` <span class="muted">(dev)</span>`:""}  ${link}${demo}`; }).join("\n");
const menu = () => `<span class="muted">navigate — type a command (or a number after </span><span class="amber">projects</span><span class="muted">):</span>
  <span class="accent">about</span>       <span class="accent">experience</span>   <span class="accent">credentials</span>
  <span class="accent">projects</span>    <span class="accent">skills</span>       <span class="accent">stats</span>
  <span class="accent">github</span>      <span class="accent">linkedin</span>     <span class="accent">résumé</span>       <span class="accent">email</span>
<span class="muted">tip: </span><span class="amber">projects</span><span class="muted"> then </span><span class="amber">open 2</span><span class="muted"> to jump straight to a repo.</span>`;
const CMD = {
  help(){ return menu(); }, menu(){ return menu(); },
  about(){ return esc(SITE.bio); },
  experience(){ return SITE.experience.map((e) => `<span class="lob">▸</span> <b>${esc(e.role)}</b> <span class="muted">·</span> <span class="a2">${esc(e.org)}</span> <span class="muted">(${esc(e.date)})</span>`).join("\n"); },
  credentials(){ return SITE.credentials.map((c) => { const v = c.link ? `  <span class="tlink" data-open="${esc(c.link)}">${esc((c.linkText||"view certificate").replace("view","open"))} ↗</span>` : ""; return `<span class="lob">▸</span> <b>${esc(c.org)}</b> <span class="muted">— ${esc(c.label)} (${esc(c.tag)})</span>${v}`; }).join("\n"); },
  skills(){ return SITE.skills.join(" · "); },
  stats(){ return SITE.kpis.map((k) => `${k.n} — ${esc(k.l)}`).join("\n") + `\n<span class="tlink" data-open="https://github.com/${SITE.github}">→ github.com/${SITE.github}</span>`; },
  projects(){ return `<span class="muted">${SITE.projects.length} builds — click a repo, or type </span><span class="amber">open &lt;n&gt;</span>\n` + projList(); },
  open(a){ const i = parseInt(a,10); let p = null; if(!isNaN(i)) p = SITE.projects[i-1]; else p = SITE.projects.find((x) => x.name.toLowerCase().includes(String(a||"").toLowerCase()));
    if(!p) return `<span style="color:var(--red)">usage: open &lt;number&gt; — see</span> <span class="amber">projects</span>`;
    if(!p.github) return `${esc(p.name)} is <span class="amber">in development</span> (repo private).`; OPEN(p.github); return `→ opening <b>${esc(p.name)}</b> repo…`; },
  github(){ OPEN(SITE.links.github); return "→ opening GitHub…"; },
  linkedin(){ OPEN(SITE.links.linkedin); return "→ opening LinkedIn…"; },
  "résumé"(){ OPEN(SITE.links["résumé"]); return "→ opening résumé (PDF)…"; }, resume(){ return CMD["résumé"](); },
  email(){ OPEN(SITE.links.email); return "→ opening email…"; },
  contact(){ return `email: <span class="tlink" data-open="${esc(SITE.links.email)}">${esc(SITE.email)}</span>`; },
  clear(){ history.innerHTML=""; return null; },
};
function run(raw){ const s = raw.trim(); pp(s); if(!s) return; const parts = s.split(/\s+/); const n = parts[0].toLowerCase(); const arg = parts.slice(1).join(" ");
  const f = CMD[n]; if(f){ const o = f(arg); if(o!=null) tp(o); } else tp(`<span style="color:var(--red)">command not found: ${esc(n)}</span> · type <span class="amber">help</span>`); }
tp(`<span class="muted">welcome to</span> <span class="accent">${SITE.domain}</span> 🦞  <span class="muted">— I'm Luke.</span>`);
tp(menu());
inputline.hidden = false;
document.addEventListener("click", (e) => { const o = e.target.closest("[data-open]"); if(o) OPEN(o.dataset.open); });
screen.addEventListener("click", (e) => { if(!e.target.closest("a") && !e.target.closest("[data-open]")) cmd.focus(); });
const past = []; let hi = -1;
cmd.addEventListener("keydown", (e) => { if(e.key==="Enter"){ const v=cmd.value; if(v.trim()){past.push(v);hi=past.length;} run(v); cmd.value=""; }
  else if(e.key==="ArrowUp"){ if(hi>0){hi--;cmd.value=past[hi];e.preventDefault();} }
  else if(e.key==="ArrowDown"){ if(hi<past.length-1){hi++;cmd.value=past[hi];}else{hi=past.length;cmd.value="";} } });
</script>
</body>
</html>
