---
import { site } from "../data/site";
import { TECH } from "../data/tech";
import "../styles/bento.css";

const data = {
  site: {
    domain: site.domain, email: site.email, links: site.links,
    bio: site.bio, credentials: site.credentials, stack: site.about.stack,
    experience: site.experience, projects: site.projects, kpis: site.kpis, focusBars: site.focusBars,
  },
  tech: TECH,
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{site.name} — {site.domain}</title>
  <meta name="description" content={`${site.name} — CS @ FSU, Data Analyst II. A single-screen dashboard, monitored by Oscar.`} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>
<div class="dash">
  <header id="brand">
    <div>
      <h1>luke salem<span class="dot">_</span></h1>
      <div class="tag">CS @ FSU '27 · <b>Data Analyst II</b> · software + data + finance</div>
    </div>
    <nav class="navlinks" id="navlinks"></nav>
  </header>

  <section class="tile" id="tile-term">
    <div class="lbl"><span><b>~/</b>terminal</span></div>
    <div id="screen" role="log" aria-live="polite">
      <div id="history"></div>
      <div id="inputline" hidden><span class="prompt">luke</span><span class="muted">@</span><span class="path">dev</span><span class="muted">:~$</span>
        <input id="cmd" autocomplete="off" autocapitalize="off" spellcheck="false" aria-label="terminal input" /></div>
    </div>
    <span class="monitor">monitored by <b>Oscar</b> 🦞</span>
  </section>

  <section class="tile click" id="tile-projects" data-modal="projects">
    <div class="lbl"><span><b>~/</b>projects</span><span class="open">open ↗</span></div>
    <div class="teaser"><span class="big" id="projN"></span> <span class="muted">builds shipped</span><div class="proj-mini" id="projMini"></div></div>
  </section>

  <section class="tile click" id="tile-about" data-modal="about">
    <div class="lbl"><span><b>~/</b>about</span><span class="open">open ↗</span></div>
    <div class="teaser">who I am, and the receipts —<br/>Vanderbilt · Harvard · Stanford · IBM.
      <div class="chips" style="margin-top:10px"><span class="chip">research</span><span class="chip">certs</span><span class="chip">FSU '27</span></div></div>
  </section>

  <section class="tile click" id="tile-stats" data-modal="stats">
    <div class="lbl"><span><b>~/</b>stats</span><span class="open">open ↗</span></div>
    <div class="teaser"><div class="kpi-row" id="kpiMini"></div><div class="heat-mini" id="heatMini"></div></div>
  </section>

  <section class="tile click" id="tile-exp" data-modal="experience">
    <div class="lbl"><span><b>~/</b>experience</span><span class="open">open ↗</span></div>
    <div class="teaser"><div class="exp-mini" id="expMini"></div></div>
  </section>

  <section class="tile" id="tile-contact">
    <div class="lbl"><span><b>~/</b>contact</span></div>
    <div class="contact-links" id="contactLinks"></div>
  </section>
</div>

<div id="ov"><div class="pwrap panel" id="panel"><span class="pclose" id="pclose">×</span><div id="panelBody"></div></div></div>
<div id="load"><div class="lcard"><div id="loadScene"></div><div class="cap">Oscar's opening <b id="loadName">that</b>…</div></div></div>
<div id="oscarLayer"><div id="bubble"></div><div id="ball"></div><div id="oscar"></div></div>

<script type="application/json" id="data" set:html={JSON.stringify(data)}></script>

<script>
const D = JSON.parse(document.getElementById("data").textContent);
const SITE = D.site, TECH = D.tech;
const $ = (id) => document.getElementById(id);
const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;" }[c]));

function oscarSVG(size){ return `
<svg class="oscar osvg" viewBox="0 0 160 160" width="${size}" height="${size}" role="img" aria-label="Oscar the Lobster" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
 <g class="bob" fill="var(--l)">
  <rect x="60" y="26" width="6" height="10" fill="var(--d)"/><rect x="54" y="16" width="6" height="10" fill="var(--d)"/><rect x="49" y="8" width="6" height="8" fill="var(--d)"/>
  <rect x="94" y="26" width="6" height="10" fill="var(--d)"/><rect x="100" y="16" width="6" height="10" fill="var(--d)"/><rect x="106" y="8" width="6" height="8" fill="var(--d)"/>
  <g class="claw"><rect x="14" y="42" width="26" height="9"/><rect x="14" y="58" width="18" height="9"/><rect x="14" y="42" width="7" height="9" fill="var(--h)"/><rect x="38" y="54" width="18" height="8" fill="var(--d)"/></g>
  <rect x="120" y="42" width="26" height="9"/><rect x="128" y="58" width="18" height="9"/><rect x="139" y="42" width="7" height="9" fill="var(--h)"/><rect x="104" y="54" width="18" height="8" fill="var(--d)"/>
  <rect x="56" y="40" width="48" height="26"/><rect x="56" y="40" width="14" height="7" fill="var(--h)"/><rect x="98" y="40" width="6" height="26" fill="var(--d)"/>
  <rect x="63" y="47" width="13" height="13" fill="#fff"/><rect x="84" y="47" width="13" height="13" fill="#fff"/>
  <rect x="67" y="51" width="6" height="7" fill="#14181f"/><rect x="88" y="51" width="6" height="7" fill="#14181f"/>
  <rect class="lid" x="63" y="47" width="13" height="13" fill="var(--l)"/><rect class="lid b" x="84" y="47" width="13" height="13" fill="var(--l)"/>
  <rect x="58" y="66" width="44" height="15"/><rect x="58" y="66" width="44" height="3" fill="var(--d)"/><rect x="96" y="66" width="6" height="15" fill="var(--d)"/>
  <rect x="61" y="81" width="38" height="15"/><rect x="61" y="81" width="38" height="3" fill="var(--d)"/><rect x="93" y="81" width="6" height="15" fill="var(--d)"/>
  <rect x="64" y="96" width="32" height="14"/><rect x="64" y="96" width="32" height="3" fill="var(--d)"/><rect x="90" y="96" width="6" height="14" fill="var(--d)"/>
  <rect x="50" y="74" width="8" height="7" fill="var(--d)"/><rect x="102" y="74" width="8" height="7" fill="var(--d)"/><rect x="52" y="88" width="8" height="7" fill="var(--d)"/><rect x="100" y="88" width="8" height="7" fill="var(--d)"/>
  <rect x="64" y="110" width="32" height="10"/><rect x="64" y="110" width="32" height="3" fill="var(--d)"/>
  <rect x="54" y="120" width="20" height="13"/><rect x="72" y="120" width="16" height="13"/><rect x="86" y="120" width="20" height="13"/>
  <rect x="54" y="127" width="8" height="6" fill="var(--d)"/><rect x="98" y="127" width="8" height="6" fill="var(--d)"/><rect x="76" y="128" width="8" height="5" fill="var(--d)"/>
 </g></svg>`; }
function oscarLaptop(){ return `
<svg class="oscar" viewBox="0 0 200 150" width="150" height="112" role="img" aria-label="Oscar with a laptop" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
 <g class="bob">
  <rect x="86" y="8" width="6" height="9" fill="var(--d)"/><rect x="80" y="0" width="6" height="9" fill="var(--d)"/><rect x="108" y="8" width="6" height="9" fill="var(--d)"/><rect x="114" y="0" width="6" height="9" fill="var(--d)"/>
  <rect x="80" y="20" width="40" height="22" fill="var(--l)"/><rect x="80" y="20" width="12" height="6" fill="var(--h)"/>
  <rect x="86" y="26" width="10" height="10" fill="#fff"/><rect x="104" y="26" width="10" height="10" fill="#fff"/>
  <rect x="89" y="29" width="5" height="6" fill="#14181f"/><rect x="107" y="29" width="5" height="6" fill="#14181f"/>
  <rect class="lid" x="86" y="26" width="10" height="10" fill="var(--l)"/><rect class="lid b" x="104" y="26" width="10" height="10" fill="var(--l)"/>
  <rect x="84" y="42" width="32" height="12" fill="var(--l)"/><rect x="34" y="52" width="20" height="9" fill="var(--l)"/><rect x="146" y="52" width="20" height="9" fill="var(--l)"/>
 </g>
 <rect x="50" y="60" width="100" height="60" rx="4" fill="#0e131c" stroke="#2b3850" stroke-width="2"/>
 <rect x="58" y="70" width="84" height="30" rx="2" fill="#0a0e15" stroke="#1e2634" stroke-width="1"/>
 <rect id="loadbar" x="62" y="102" width="0" height="6" rx="3" fill="#e5484d"/>
 <rect x="40" y="118" width="120" height="8" rx="3" fill="#161c28" stroke="#2b3850" stroke-width="1.5"/></svg>`; }

const badge = (n) => { const t = TECH[n] || { bg:"#232b3a", fg:"#cfd8e6" }; const ic = t.icon ? `<img src="https://cdn.simpleicons.org/${t.icon}/${t.ic}" alt="" loading="lazy" onerror="this.remove()"/>` : ""; return `<span class="badge" style="background:${t.bg};color:${t.fg}">${ic}${esc(n)}</span>`; };

const HEAT = []; for (let x=0;x<51;x++) for (let y=0;y<7;y++){ let s=Math.sin(x*12.9898+y*78.233)*43758.5453; let r=s-Math.floor(s); r*=(x>37?1.35:1); HEAT.push(r<0.5?0:r<0.7?1:r<0.85?2:r<0.95?3:4); }

$("navlinks").innerHTML = Object.entries(SITE.links).map(([k,v]) => `<a class="oscar-link" data-href="${esc(v)}" data-name="${k}">${k}</a>`).join("");
$("projN").textContent = SITE.projects.length;
$("projMini").innerHTML = SITE.projects.slice(0,4).map(p => `<div class="p">${esc(p.name)}${p.status?`<span class="st">dev</span>`:""}<span class="tk">${esc(p.tech[0])}</span></div>`).join("");
$("kpiMini").innerHTML = SITE.kpis.map(k => `<div class="k"><div class="n">${k.n}</div><div class="l">${esc(k.l)}</div></div>`).join("");
$("heatMini").innerHTML = HEAT.filter((_,i)=>i%2===0).map(l => `<i data-l="${l}"></i>`).join("");
$("expMini").innerHTML = SITE.experience.map(e => `<div class="e"><div class="r">${esc(e.role)}</div><div class="o">${esc(e.org)}</div></div>`).join("");
$("contactLinks").innerHTML = Object.entries(SITE.links).map(([k,v]) => `<a class="oscar-link" data-href="${esc(v)}" data-name="${k}">${k}<span class="muted">↗</span></a>`).join("");

const ov = $("ov"), panelBody = $("panelBody");
const creds = () => SITE.credentials.map(c => `<div class="cred"><div class="o">${esc(c.org)}<span class="tg ${/progress/i.test(c.tag)?'prog':''}">${esc(c.tag)}</span></div><div class="ll">${esc(c.label)}</div><div class="nn">${esc(c.note)}</div></div>`).join("");
const MODALS = {
  about: () => `<h2>about</h2><div class="sub">// whoami</div><p class="bio">${esc(SITE.bio)}</p><div class="creds">${creds()}</div><div class="chips">${SITE.stack.map(s=>`<span class="chip">${esc(s)}</span>`).join("")}</div>`,
  projects: () => `<h2>projects</h2><div class="sub">// ${SITE.projects.length} builds</div>` + SITE.projects.map(p => {
    const L=[]; if(p.github)L.push(`<a class="oscar-link" data-href="${esc(p.github)}" data-name="${esc(p.name)} repo">code ↗</a>`);
    if(p.live)L.push(`<a class="oscar-link" data-href="${esc(p.live)}" data-name="${esc(p.name)} demo">demo ↗</a>`);
    if(!p.github&&!p.live)L.push(`<span class="priv">private · in dev</span>`);
    return `<div class="pcard"><div class="ct"><h3>${esc(p.name)}</h3>${p.status?`<span class="status">${esc(p.status)}</span>`:""}</div><p class="d">${esc(p.desc)}</p><div class="badges">${p.tech.map(badge).join("")}</div><div class="plinks">${L.join("")}</div></div>`; }).join(""),
  experience: () => `<h2>experience</h2><div class="sub">// where I've worked</div><div class="tl">` + SITE.experience.map(e => `<div class="row"><div class="r1"><span class="role">${esc(e.role)} <span class="muted">@</span> <span style="color:var(--a2)">${esc(e.org)}</span></span><span class="date">${esc(e.date)}</span></div><div class="note">${esc(e.note)}</div></div>`).join("") + `</div>`,
  stats: () => `<h2>stats</h2><div class="sub">// by the numbers</div>
    <div class="kpi-row" style="gap:22px;margin-bottom:14px">${SITE.kpis.map(k=>`<div class="k"><div class="n" style="font-size:24px">${k.n}</div><div class="l">${esc(k.l)}</div></div>`).join("")}</div>
    <div style="color:var(--muted);font-size:12px;margin-bottom:4px">contribution activity <span style="color:var(--dim)">// sample — wire to live GitHub</span></div>
    <div class="heatbig">${HEAT.map(l=>`<i data-l="${l}"></i>`).join("")}</div>
    <div class="legend">less <i style="background:#151b26"></i><i style="background:#4a181b"></i><i style="background:#8f2329"></i><i style="background:#c72f36"></i><i style="background:#ff5a5f"></i> more</div>
    <div style="color:var(--muted);font-size:12px;margin:16px 0 6px">focus areas <span style="color:var(--dim)">// self-assessed</span></div>
    ${SITE.focusBars.map(b=>`<div class="bar"><span>${esc(b.lbl)}</span><span class="track"><span class="fill" style="width:${b.pct}%"></span></span><span class="muted" style="text-align:right">${b.pct}%</span></div>`).join("")}`,
};
function openModal(id){ const f = MODALS[id]; if(!f) return; panelBody.innerHTML = f(); ov.classList.add("on"); oscar.peekAt(); }
function closeModal(){ ov.classList.remove("on"); }
document.querySelectorAll(".tile.click").forEach(t => t.addEventListener("click", () => openModal(t.dataset.modal)));
$("pclose").addEventListener("click", closeModal);
ov.addEventListener("click", (e) => { if(e.target===ov) closeModal(); });
document.addEventListener("keydown", (e) => { if(e.key==="Escape") closeModal(); });

const load = $("load"); $("loadScene").innerHTML = oscarLaptop();
function openWithOscar(href,name){ const w = window.open(href,"_blank","noopener"); $("loadName").textContent = name||"that";
  load.classList.add("on"); const bar = document.getElementById("loadbar"); if(bar){ bar.setAttribute("width","0"); bar.animate([{width:"0"},{width:"76"}],{duration:1000,fill:"forwards"}); }
  setTimeout(()=>{ load.classList.remove("on"); if(!w) location.href=href; }, 1150); }
document.addEventListener("click", (e) => { const a = e.target.closest(".oscar-link"); if(!a) return; e.preventDefault(); openWithOscar(a.dataset.href,a.dataset.name); });
load.addEventListener("click", () => load.classList.remove("on"));

const history = $("history"), inputline = $("inputline"), cmd = $("cmd"), screen = $("screen");
function tprint(html){ const el=document.createElement("div"); el.className="out"; el.innerHTML=html; history.appendChild(el); screen.scrollTop=screen.scrollHeight; }
function pp(t){ tprint(`<span class="prompt">luke</span><span class="muted">@</span><span class="path">dev</span><span class="muted">:~$</span> <span class="amber">${esc(t)}</span>`); }
const CMD = {
  help(){ return `commands: <span class="accent">about</span> <span class="accent">projects</span> <span class="accent">experience</span> <span class="accent">stats</span> <span class="accent">contact</span> <span class="accent">oscar</span> <span class="accent">clear</span>`; },
  about(){ openModal("about"); return "→ opening about"; },
  projects(){ openModal("projects"); return "→ opening projects"; },
  experience(){ openModal("experience"); return "→ opening experience"; },
  stats(){ openModal("stats"); return "→ opening stats"; },
  contact(){ return `email: <a class="oscar-link" data-href="mailto:${esc(SITE.email)}" data-name="email">${esc(SITE.email)}</a>`; },
  oscar(){ oscar.kick(); return `🦞 <span class="lob">Oscar</span>: "watch this —" *kicks the ball*`; },
  clear(){ history.innerHTML=""; return null; },
};
function run(raw){ const s=raw.trim(); pp(s); const n=s.split(" ")[0].toLowerCase(); if(n==="")return; const f=CMD[n];
  if(f){ const o=f(); if(o!=null) tprint(o); } else tprint(`<span style="color:var(--red)">command not found: ${esc(n)}</span> · try <span class="amber">help</span>`); }
tprint(`<span class="muted">welcome to</span> <span class="accent">${SITE.domain}</span> <span class="muted">— type</span> <span class="amber">help</span>`);
inputline.hidden = false;
const past = []; let hi = -1;
cmd.addEventListener("keydown", (e) => { if(e.key==="Enter"){ const v=cmd.value; if(v.trim()){past.push(v);hi=past.length;} run(v); cmd.value=""; }
  else if(e.key==="ArrowUp"){ if(hi>0){hi--;cmd.value=past[hi];e.preventDefault();} }
  else if(e.key==="ArrowDown"){ if(hi<past.length-1){hi++;cmd.value=past[hi];}else{hi=past.length;cmd.value="";} } });
screen.addEventListener("click", (e) => { if(!e.target.closest("a")) cmd.focus(); });

const oscar = (function(){
  const el = $("oscar"), ball = $("ball"), bubble = $("bubble");
  el.innerHTML = oscarSVG(70);
  let x = innerWidth*0.5, y = innerHeight*0.68, face = 1, busy = false, mouseX = x;
  const S = 70;
  const bounds = () => ({ minx:14, maxx:innerWidth-S-14, miny:innerHeight*0.34, maxy:innerHeight-S-16 });
  function place(){ el.style.transform = `translate(${x}px,${y}px) scaleX(${face})`; }
  place();
  function walkTo(tx,ty,dur=1700){ const b=bounds(); tx=Math.max(b.minx,Math.min(b.maxx,tx)); ty=Math.max(b.miny,Math.min(b.maxy,ty));
    face=(tx<x)?-1:1; el.style.transitionDuration=(dur/1000)+"s"; el.classList.add("walk"); x=tx; y=ty; place();
    clearTimeout(el._wt); el._wt=setTimeout(()=>el.classList.remove("walk"),dur); }
  function snap(){ el.classList.remove("snap"); void el.offsetWidth; el.classList.add("snap"); }
  function say(t){ bubble.textContent=t; bubble.style.transform=`translate(${x+8}px,${y-14}px)`; bubble.style.opacity=1; clearTimeout(bubble._t); bubble._t=setTimeout(()=>bubble.style.opacity=0,1400); }
  function hop(){ el.classList.remove("hop"); void el.offsetWidth; el.classList.add("hop"); }
  function kick(){
    if(busy)return; busy=true;
    const b=bounds(); const bx=x+(face>0?54:2), by=y+38;
    ball.style.opacity=1; ball.style.transform=`translate(${bx}px,${by}px)`; snap(); hop();
    const tx=Math.max(20,Math.min(innerWidth-30, x+face*(180+Math.random()*160)));
    const ty=Math.max(b.miny+20,Math.min(innerHeight-30, by-40-Math.random()*120));
    const midx=(bx+tx)/2, midy=Math.min(by,ty)-90;
    ball.animate([{transform:`translate(${bx}px,${by}px) rotate(0deg)`},{transform:`translate(${midx}px,${midy}px) rotate(360deg)`,offset:.5},{transform:`translate(${tx}px,${ty}px) rotate(720deg)`}],{duration:950,easing:"ease-out",fill:"forwards"});
    setTimeout(()=>{ ball.animate([{opacity:1},{opacity:0}],{duration:500,fill:"forwards"}); },1400);
    setTimeout(()=>busy=false,1200);
  }
  el.addEventListener("click",()=>{ hop(); snap(); say(["🦞!","hi!","click!","boop"][Math.floor(Math.random()*4)]); });
  addEventListener("mousemove",(e)=>{ mouseX=e.clientX; if(!el.classList.contains("walk")){ face=(mouseX<x+S/2)?-1:1; place(); } },{passive:true});
  function roam(){ const b=bounds(); const tx=b.minx+Math.random()*(b.maxx-b.minx); const ty=b.miny+Math.random()*(b.maxy-b.miny); walkTo(tx,ty,1400+Math.random()*1200); }
  setInterval(()=>{ if(!busy && !ov.classList.contains("on")) roam(); },2600);
  setInterval(()=>{ if(!busy) snap(); },4200);
  setInterval(()=>{ if(!busy && Math.random()<0.75) kick(); },8000);
  function peekAt(){ const p=document.querySelector(".panel").getBoundingClientRect();
    walkTo(Math.min(bounds().maxx,p.right-40),Math.min(bounds().maxy,p.bottom-30),900); setTimeout(()=>{ face=-1; place(); say("👀"); },1000); }
  addEventListener("resize",()=>{ const b=bounds(); x=Math.min(x,b.maxx); y=Math.min(y,b.maxy); place(); });
  return { kick, snap, peekAt };
})();
</script>
</body>
</html>
